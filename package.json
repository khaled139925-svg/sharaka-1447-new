{
  "name": "sharaka-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "pnpm run build:clean && pnpm install --no-optional --no-frozen-lockfile && vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:clean": "rm -rf node_modules/.vite dist 2>/dev/null || true",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
  },
  "dependencies": {
    "@trpc/client": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.263.1",
    "multer": "^2.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.1",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
