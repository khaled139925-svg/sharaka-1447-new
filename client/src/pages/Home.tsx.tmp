            <div className="container mx-auto px-4 py-4 space-y-3">
              <a href="#consultants" onClick={() => setShowMenu(false)} className="block px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-300 font-semibold">Consultants</a>
              <a href="#services" onClick={() => setShowMenu(false)} className="block px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-300 font-semibold">Services</a>
              <a href="#marketplace" onClick={() => setShowMenu(false)} className="block px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-300 font-semibold">Marketplace</a>
              <a href="#paths" onClick={() => setShowMenu(false)} className="block px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-300 font-semibold">Paths</a>
              <a href="#points" onClick={() => setShowMenu(false)} className="block px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-300 font-semibold">Points</a>
              <a href="#contact" onClick={() => setShowMenu(false)} className="block px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-all duration-300 font-semibold">Contact</a>
