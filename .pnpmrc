# pnpm configuration for CI/CD environments
# This configuration prevents ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY errors

# CRITICAL: Tell pnpm this is a CI environment
ci-mode=true

# CRITICAL: Force removal of modules without TTY confirmation
force=true

# Disable interactive mode completely
interactive=false

# Installation settings
shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
prefer-frozen-lockfile=false

# Node linker settings
node-linker=hoisted

# Build and verification settings
ignore-scripts=false
verify-store-integrity=false
recursive-install=true

# Disable optional dependencies in CI
optional=false

# Additional CI-specific settings
store-dir=.pnpm-store
